# AlHudhud Connect - Environment Variables

# Gateway API (Backend للمصادقة والمزامنة)
EXPO_PUBLIC_API_URL=http://localhost:4000/api

# Gateway Base URL (يُستخدم لـ WebSocket والـ REST)
EXPO_PUBLIC_GATEWAY_URL=http://localhost:4000

# Gateway WebSocket (يُشتق تلقائياً من GATEWAY_URL إذا لم يُحدد)
EXPO_PUBLIC_WS_URL=ws://localhost:4000/ws

# Google OAuth (لتسجيل الدخول بحساب Google)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Supabase (مرسل الهدهد - المنصة)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Gateway Server Environment ─────────────────────────────

# JWT Secret (مفتاح توقيع JWT — يجب أن يكون 16 حرفاً على الأقل)
JWT_SECRET=

# Server Port
PORT=4000

# CORS Origins (مفصولة بفواصل — مثال: http://localhost:19006,https://myapp.com)
CORS_ORIGINS=

# Webhook Secret (لتحقق HMAC من الطلبات الواردة)
WEBHOOK_SECRET=

# Admin Default Password (كلمة مرور المدير الافتراضية عند التشغيل الأول)
ADMIN_DEFAULT_PASSWORD=

# Supabase (اختياري — للمزامنة مع Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Google OAuth (لتسجيل الدخول بحساب Google)
GOOGLE_CLIENT_ID=

# SMTP (اختياري — لإرسال الإيميلات)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
